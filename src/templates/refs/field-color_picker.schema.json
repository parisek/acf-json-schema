    "$id": "https://schemas.parisek.dev/acf/refs/field-color_picker.schema.json",
    "title": "ACF Field — Color Picker",
    "type": "object",
    "properties": {
        "default_value": { "type": ["string", "null"] },
        "enable_opacity": { "enum": [true, false, 0, 1] },
