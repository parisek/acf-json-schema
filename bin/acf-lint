#!/usr/bin/env php
<?php
declare(strict_types=1);

// Resolve the autoloader whether installed as a dependency (vendor/bin) or run
// from the package root.
$autoloads = [
    __DIR__ . '/../vendor/autoload.php',            // standalone checkout
    __DIR__ . '/../../../autoload.php',             // installed in a consumer's vendor/
];
$autoloaded = false;
foreach ($autoloads as $a) {
    if (file_exists($a)) {
        require_once $a;
        $autoloaded = true;
        break;
    }
}
if (!$autoloaded) {
    fwrite(STDERR, "Error: Composer autoloader not found. Run `composer install`, or install this package as a dependency and use vendor/bin/acf-lint.\n");
    exit(1);
}

use Parisek\AcfJsonSchema\Lint\AcfLinter;
use Parisek\AcfJsonSchema\Lint\CliOptions;
use Parisek\AcfJsonSchema\Lint\Reporter;

$opts = CliOptions::parse(array_slice($argv, 1));

if ($opts->error !== null) {
    fwrite(STDERR, "Error: {$opts->error}. Run acf-lint --help for usage.\n");
    exit(1);
}

if ($opts->version) {
    $version = \Composer\InstalledVersions::isInstalled('parisek/acf-json-schema')
        ? \Composer\InstalledVersions::getPrettyVersion('parisek/acf-json-schema')
        : 'unknown';
    fwrite(STDOUT, "acf-lint {$version}\n");
    exit(0);
}

if ($opts->help || $opts->paths === []) {
    fwrite(STDERR, <<<USAGE
    acf-lint — validate ACF / CPT / taxonomy / block JSON against parisek/acf-json-schema.

    Usage:
      acf-lint [--strict] [--fix] [--wpml] [--format=<text|json|github>] [--max-errors=<N>] [--] <path>...

      <path>          File or directory (directories are walked recursively for *.json)
      --strict        Exit 1 if any file has findings (CI gate)
      --fix           Auto-bump stale/missing `modified` timestamps
      --wpml          Require WPML/ACFML translation keys to be PRESENT on field
                      groups (acfml_field_group_mode) and every field
                      (wpml_cf_preferences). Opt-in; schemas keep them optional.
      --format=<f>    Output format: text (default; findings on stderr, summary
                      on stdout), json (one machine-readable document on stdout),
                      github (GitHub Actions ::error annotations on stdout)
      --max-errors=<N>  Cap schema errors collected per file (default 50)
      --version       Print the installed package version
      --              Treat every following argument as a path (even if it starts with -)

    Colors: text format only, auto-disabled when stderr is not a TTY or NO_COLOR is set.

    Exit codes: 0 ok (or findings without --strict), 1 findings under --strict / bad args.

    USAGE);
    exit($opts->paths === [] && !$opts->help ? 1 : 0);
}

$linter = new AcfLinter(__DIR__ . '/../schemas', $opts->maxErrors);
$files = $linter->collectJsonFiles($opts->paths);

$results = [];
foreach ($files as $file) {
    $results[] = $linter->lintFile($file, $opts->fix, $opts->wpml);
}

// Findings go to stderr in text format, so color follows stderr's TTY-ness.
$color = getenv('NO_COLOR') === false && function_exists('stream_isatty') && @stream_isatty(STDERR);
$out = (new Reporter($color))->render($results, $opts->format);
if ($out['stderr'] !== '') {
    fwrite(STDERR, $out['stderr']);
}
fwrite(STDOUT, $out['stdout']);

$errorFiles = count(array_filter($results, static fn ($r): bool => !$r->skipped && !$r->valid));
exit(($opts->strict && $errorFiles > 0) ? 1 : 0);
